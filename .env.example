# Backrest base URL (default: http://localhost:9898)
BACKREST_URL=http://localhost:9898

# Basic auth (optional — omit if auth is disabled)
BACKREST_USERNAME=
BACKREST_PASSWORD=

# TLS: if using a private CA, set:
# REQUESTS_CA_BUNDLE=/path/to/ca.crt (httpx respects this)
# Do NOT disable TLS verification.

# Safety controls
# BACKREST_READONLY=true         — read-only mode; no write tools registered (default: true)
# BACKREST_ALLOW_DESTRUCTIVE=false — enables forget_snapshot and restore_snapshot (default: false)
#                                    requires BACKREST_READONLY=false
# BACKREST_RESTORE_ALLOWED_PREFIX=/tmp/backrest-restore/  — restore target must be under this path
# BACKREST_AUDIT_LOG=            — path for write-op audit log (JSONL); empty = disabled

# Logging
LOG_LEVEL=INFO
LOG_FILE=

# Optional InfluxDB metrics
INFLUXDB_URL=
