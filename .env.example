# Copy to .env and fill in your values.
# This file must NOT be committed — it is listed in .gitignore.

# Backrest base URL. Default: http://localhost:9898
BACKREST_URL=http://localhost:9898

# Basic auth credentials — only required if Backrest auth is enabled.
# Leave both empty to connect without authentication.
BACKREST_USERNAME=
BACKREST_PASSWORD=

# TLS note: If connecting to an HTTPS endpoint with a private/self-signed CA,
# set NODE_EXTRA_CA_CERTS=/path/to/ca.crt in your environment.
# Do NOT use NODE_TLS_REJECT_UNAUTHORIZED=0 — that disables all cert verification.
